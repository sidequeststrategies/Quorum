# Production environment template.
#
# Set these as Environment Variables in your Vercel project (Settings → Environment Variables),
# NOT in a committed .env file. Mark each as "Sensitive" where appropriate.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTES_BASE64"
AUTH_TRUST_HOST="true"

# Used by Auth.js to construct callback URLs. Must match the deployed origin.
NEXTAUTH_URL="https://quorum.sidequeststrategies.com"

# ── Database (Turso/libSQL via HTTP) ────────────────────────────────────────
# Get the URL + token from https://app.turso.tech after creating a database.
DATABASE_URL="libsql://your-database-name-orgname.turso.io"
DATABASE_AUTH_TOKEN="REPLACE_WITH_TURSO_AUTH_TOKEN"

# ── File storage (Vercel Blob) ──────────────────────────────────────────────
STORAGE_DRIVER="vercel-blob"
# BLOB_READ_WRITE_TOKEN is auto-injected when you connect a Blob store to your
# Vercel project — no need to set this manually.

# ── AI assistant (optional — disables /chat if unset) ───────────────────────
ANTHROPIC_API_KEY=""

# ── Node ────────────────────────────────────────────────────────────────────
NODE_ENV="production"
