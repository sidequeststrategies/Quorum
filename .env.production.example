# Production environment template.
#
# Set these as Environment Variables in your Vercel project (Settings → Environment Variables),
# NOT in a committed .env file. Mark each as "Sensitive" where appropriate.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTES_BASE64"
AUTH_TRUST_HOST="true"

# Used by Auth.js to construct callback URLs. Must match the deployed origin.
NEXTAUTH_URL="https://quorum.sidequeststrategies.com"

# ── Database (Turso/libSQL via HTTP) ────────────────────────────────────────
# Get the URL + token from https://app.turso.tech after creating a database.
DATABASE_URL="libsql://your-database-name-orgname.turso.io"
DATABASE_AUTH_TOKEN="REPLACE_WITH_TURSO_AUTH_TOKEN"

# ── File storage ─────────────────────────────────────────────────────────────
# "db" stores files as Postgres rows served through the authenticated
# /api/files/[id] route — private, org-scoped, audit-logged. Use this in
# production; board documents must not sit on public URLs.
# ("vercel-blob" remains only for legacy rows: Blob URLs are public-by-URL.)
STORAGE_DRIVER="db"

# ── AI assistant (optional — disables /chat if unset) ───────────────────────
ANTHROPIC_API_KEY=""

# ── HubSpot live funnel (optional — funnel falls back to Excel if unset) ────
# Private-app token, scope crm.objects.deals.read. Mark as Sensitive.
HUBSPOT_ACCESS_TOKEN=""
# Defaults: pipeline "default", AssetCool stage map (see src/lib/hubspot.ts).
HUBSPOT_PIPELINE_ID=""
HUBSPOT_STAGE_MAP=""

# ── Branding ─────────────────────────────────────────────────────────────────
# Reporting currency for all displayed figures (AssetCool: GBP).
NEXT_PUBLIC_BRAND_CURRENCY="GBP"

# ── Node ────────────────────────────────────────────────────────────────────
NODE_ENV="production"
