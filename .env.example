DATABASE_URL="file:./data/quorum.db"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Optional — enables the AI assistant (/chat). Without it, the rest of Quorum works fine.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Optional — live sales funnel from HubSpot. Create a private app
# (Settings → Integrations → Private Apps) with scope crm.objects.deals.read.
# Unset → the funnel section falls back to Excel board-pack imports.
HUBSPOT_ACCESS_TOKEN=""
# Pipeline to read (default "default") and an optional stage-map override:
# JSON of { "<hubspot stage id>": "LEAD|QUALIFIED|PROPOSAL|NEGOTIATION|CLOSED_WON|CLOSED_LOST" }.
HUBSPOT_PIPELINE_ID=""
HUBSPOT_STAGE_MAP=""
# Deep links from /pipelinereport into HubSpot (defaults: AssetCool's portal).
HUBSPOT_PORTAL_ID=""
HUBSPOT_UI_DOMAIN=""
# Dev-only: fixture deals for /pipelinereport when no token is set.
PIPELINE_REPORT_FIXTURE=""
# Guests who may Google-sign-in to view ONLY /pipelinereport (comma-separated).
PIPELINE_REPORT_GUEST_EMAILS=""

# Reporting currency for all displayed figures (default USD; AssetCool: GBP).
NEXT_PUBLIC_BRAND_CURRENCY=""
